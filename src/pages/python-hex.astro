---
import { Image } from 'astro:assets';
import BaseLayout from '../layouts/BaseLayout.astro';
import hexBigImg from '../assets/images/hex_big.png';
import hexSmallImg from '../assets/images/hex_small.png';
---

<BaseLayout
  title="Hex Board"
  description="A Python hex board that draws a line between two selected hexes."
>
  <div class="page-header">
    <h1>Hex Board</h1>
  </div>

  <p>
    A hex-based board built with Python. The pink line is automatically created
    between the red and blue hexes. Click either colored hex to reposition it.
  </p>

  <p>
    <a
      href="https://github.com/jmfernandes/Python/blob/master/pyqt/hex.py"
      target="_blank"
      rel="noopener">View on GitHub &rarr;</a
    >
  </p>

  <p>Large board:</p>
  <Image src={hexBigImg} alt="Large hex board" />

  <p>Small board:</p>
  <Image src={hexSmallImg} alt="Small hex board" />
</BaseLayout>
